# Copy to .env and provide a project API key locally. Do not commit .env.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_TIMEOUT_MS=150000
PORT=8787
# Exact browser origins allowed to call Express (comma-separated; no wildcard).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

# Hosted-judge safeguards (required only when NODE_ENV=production).
# Keep the ledger on durable storage and use a short one-time bootstrap window.
JUDGE_ACCESS_EXPIRES_AT=2026-08-07T00:00:00Z
OPENAI_INTERNAL_BUDGET_USD=9
BUDGET_LEDGER_PATH=/absolute/path/to/durable/agriverse-openai-budget.json
BUDGET_LEDGER_BOOTSTRAP_UNTIL=REPLACE_WITH_SHORT_INITIAL_DEPLOY_WINDOW
MODEL_GLOBAL_CONCURRENCY=2
MODEL_SESSION_CONCURRENCY=1
HTTP_MODEL_GLOBAL_CONCURRENCY=2
HTTP_MODEL_SESSION_CONCURRENCY=1
DEPLOYED_COMMIT=local
