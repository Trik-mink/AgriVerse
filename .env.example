# Copy to .env and provide a project API key locally. Do not commit .env.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
PORT=8787
# Exact browser origins allowed to call Express (comma-separated; no wildcard).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000
