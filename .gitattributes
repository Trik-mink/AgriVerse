# Unity asset metadata is text and must stay in version control.
unity/**/*.meta text eol=lf

# Large Unity source assets use Git LFS. Build output remains ignored.
unity/**/*.fbx filter=lfs diff=lfs merge=lfs -text
unity/**/*.obj filter=lfs diff=lfs merge=lfs -text
unity/**/*.blend filter=lfs diff=lfs merge=lfs -text
unity/**/*.dae filter=lfs diff=lfs merge=lfs -text
unity/**/*.3ds filter=lfs diff=lfs merge=lfs -text

unity/**/*.png filter=lfs diff=lfs merge=lfs -text
unity/**/*.jpg filter=lfs diff=lfs merge=lfs -text
unity/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
unity/**/*.tga filter=lfs diff=lfs merge=lfs -text
unity/**/*.tif filter=lfs diff=lfs merge=lfs -text
unity/**/*.tiff filter=lfs diff=lfs merge=lfs -text
unity/**/*.psd filter=lfs diff=lfs merge=lfs -text
unity/**/*.exr filter=lfs diff=lfs merge=lfs -text
unity/**/*.hdr filter=lfs diff=lfs merge=lfs -text

unity/**/*.wav filter=lfs diff=lfs merge=lfs -text
unity/**/*.mp3 filter=lfs diff=lfs merge=lfs -text
unity/**/*.ogg filter=lfs diff=lfs merge=lfs -text
unity/**/*.aif filter=lfs diff=lfs merge=lfs -text
unity/**/*.aiff filter=lfs diff=lfs merge=lfs -text
unity/**/*.flac filter=lfs diff=lfs merge=lfs -text

# Curated public documentation captures are binary release evidence.
docs/images/*.png filter=lfs diff=lfs merge=lfs -text
